{
  "@context": {
    "@version": 1.1,
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "id": "@id",
    "type": "@type",
    "bounding_box": {
      "@id": "http://www.w3.org/ns/dcat#bbox",
      "@type": "http://www.w3.org/2000/01/rdf-schema#Literal"
    },
    "name": {
      "@id": "http://purl.org/dc/terms/title",
      "@type": "xsd:string"
    },
    "geometry": {
      "@id": "http://www.w3.org/ns/locn#geometry",
      "@context": "../geometry/context.jsonld"
    },
    "related_object": {
      "@id": "https://model.ccmm.cz/vocabulary/ccmm#hasRelatedResource",
      "@container": "@set",
      "@context": "../related-resource/context.jsonld"
    },
    "relation_type": {
      "@id": "https://model.ccmm.cz/vocabulary/ccmm#hasType",
      "@context": "../location-relation-type/context.jsonld"
    },
    "Location": {
      "@id": "http://purl.org/dc/terms/Location",
      "@context": {}
    },
    "GeoLocation": {
      "@id": "https://model.ccmm.cz/vocabulary/datacite#Geolocation",
      "@context": {}
    }
  }
}