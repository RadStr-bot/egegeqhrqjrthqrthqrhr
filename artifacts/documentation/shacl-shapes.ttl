@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.

<a19ec3750f9cac81738cd8448f26565ddocumentationShape> a sh:NodeShape;
    sh:targetClass <http://xmlns.com/foaf/0.1/Document>;
    sh:class <http://xmlns.com/foaf/0.1/Document>;
    sh:nodeKind sh:IRI;
    sh:description "A textual resource intended for human consumption that contains information about the data service."@en;
    sh:name "Documentation"@en.
<7853229e8890f10925420a9fa1a560d3labelShape> a sh:PropertyShape;
    sh:description "Documentation label"@en;
    sh:name "label"@en;
    sh:path rdfs:label;
    sh:datatype <http://www.w3.org/1999/02/22-rdf-syntax-ns#langString>.
<a19ec3750f9cac81738cd8448f26565ddocumentationShape> sh:property <7853229e8890f10925420a9fa1a560d3labelShape>.
