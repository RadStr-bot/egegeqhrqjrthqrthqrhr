<8f505611fefcbf0dbbfcf14f2acab06ddistribution_downloadable_fileShape> sh:property <4a698e4de5b4ffb1108b4442e4045e7amedia_typeShape>.
<3dabd1b22937eea3c908890085327a0abyte_sizeShape> a sh:PropertyShape;
    sh:description "The size of a Distribution in bytes. "@en;
    sh:name "byte size"@en;
    sh:minCount 1;
    sh:maxCount 1;
    sh:path <http://www.w3.org/ns/dcat#byteSize>;
    sh:datatype xsd:integer.
<8f505611fefcbf0dbbfcf14f2acab06ddistribution_downloadable_fileShape> sh:property <3dabd1b22937eea3c908890085327a0abyte_sizeShape>.
<cc2515a1530ba93da6a7a38509f8291echecksumShape> a sh:PropertyShape;
    sh:description "A mechanism that can be used to verify that the contents of a distribution have not changed."@en;
    sh:name "has checksum"@en;
    sh:maxCount 1;
    sh:path <http://spdx.org/rdf/terms#checksum>;
    sh:nodeKind sh:IRI.
<50b96d99823f368a54aac52629ba182fchecksumShape> a sh:NodeShape;
    sh:class <http://spdx.org/rdf/terms#Checksum>;
    sh:nodeKind sh:IRI;
    sh:description "A value that allows the contents of a file to be authenticated."@en;
    sh:name "Checksum"@en.
<a54d76a10cff454d847ee74d7f1530d8checksum_valueShape> a sh:PropertyShape;
    sh:description "A lower case hexadecimal encoded digest value produced using a specific algorithm. "@en;
    sh:name "checksum value"@en;
    sh:minCount 1;
    sh:maxCount 1;
    sh:path <http://spdx.org/rdf/terms#checksumValue>;
    sh:datatype xsd:hexBinary.
<50b96d99823f368a54aac52629ba182fchecksumShape> sh:property <a54d76a10cff454d847ee74d7f1530d8checksum_valueShape>.
<a3ac17cb45f60f9da54fb1308343c6f7algorithmShape> a sh:PropertyShape;
    sh:description "The algorithm used to produce the subject Checksum."@en;
    sh:name "uses algorithm"@en;
    sh:minCount 1;
    sh:maxCount 1;
    sh:path <http://spdx.org/rdf/terms#algorithm>;
    sh:nodeKind sh:IRI.
<fcfe954ce1b6f585e9d7282a1c7ebdc3checksum_algorithmShape> a sh:NodeShape;
    sh:class <http://spdx.org/rdf/terms#ChecksumAlgorithm>;
    sh:nodeKind sh:IRI;
    sh:description "Algorithm used for Checksums."@en;
    sh:name "Checksum algorithm"@en.
