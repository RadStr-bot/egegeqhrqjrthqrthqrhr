<cc2515a1530ba93da6a7a38509f8291echecksumShape> sh:node <50b96d99823f368a54aac52629ba182fchecksumShape>.
<8f505611fefcbf0dbbfcf14f2acab06ddistribution_downloadable_fileShape> sh:property <cc2515a1530ba93da6a7a38509f8291echecksumShape>.
