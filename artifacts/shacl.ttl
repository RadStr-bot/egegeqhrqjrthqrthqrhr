    sh:name "address area"@en;
    sh:description " This would typically be part of a city, a neighbourhood or village, e.g. Montmartre. Address area is not an administrative unit. "@en;
    sh:nodeKind sh:Literal;
    sh:path <http://www.w3.org/ns/locn#addressArea>;
    sh:datatype xsd:string.

<https://example.com/profile/JAKL_CCMM_AP#locn:AddressShape> sh:property <https://example.com/profile/JAKL_CCMM_AP#locn:AddressShape/-2d4b50b7>.

