    sh:nodeKind sh:Literal;
    sh:path <http://www.w3.org/ns/locn#postName>;
    sh:datatype xsd:string.

<https://example.com/profile/JAKL_CCMM_AP#locn:AddressShape> sh:property <https://example.com/profile/JAKL_CCMM_AP#locn:AddressShape/4b8321f>.

<https://example.com/profile/JAKL_CCMM_AP#locn:AddressShape/4f196fc0> a sh:PropertyShape;
    sh:name "administrative unit level 1"@en;
    sh:description "Best practice is to use the ISO 3166-1 code but if this is inappropriate for the context, country names should be provided in a consistent manner to reduce ambiguity. For example, either write 'France' or 'FRA' consistently throughout the dataset and avoid mixing the two. The Country controlled vocabulary from the Publications Office can be reused for this."@en;
    sh:nodeKind sh:Literal;
    sh:path <http://www.w3.org/ns/locn#adminUnitL1>;
    sh:datatype xsd:string.

