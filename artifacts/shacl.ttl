<https://example.com/profile/JAKL_CCMM_AP#locn:AddressShape/afa9d72> a sh:PropertyShape;
    sh:name "locator designator"@en;
    sh:description "In simpler terms, this is the building number, apartment number, etc. For an address such as \"Flat 3, 17 Bridge Street\", the locator is \"flat 3, 17\". "@en;
    sh:nodeKind sh:Literal;
    sh:path <http://www.w3.org/ns/locn#locatorDesignator>;
    sh:datatype xsd:string.

<https://example.com/profile/JAKL_CCMM_AP#locn:AddressShape> sh:property <https://example.com/profile/JAKL_CCMM_AP#locn:AddressShape/afa9d72>.

<https://example.com/profile/JAKL_CCMM_AP#locn:AddressShape/-3e08a717> a sh:PropertyShape;
    sh:name "locator name"@en;
    sh:description "The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building.\n\nThe key difference between a locator designator and a locator name is that the latter is a proper name and is unlikely to include digits. For example, \"Shumann, Berlaymont\" is a meeting room within the European Commission headquarters for which locator name is more appropriate than locator. "@en;
    sh:nodeKind sh:Literal;
    sh:path <http://www.w3.org/ns/locn#locatorName>;
    sh:datatype xsd:string.

<https://example.com/profile/JAKL_CCMM_AP#locn:AddressShape> sh:property <https://example.com/profile/JAKL_CCMM_AP#locn:AddressShape/-3e08a717>.

