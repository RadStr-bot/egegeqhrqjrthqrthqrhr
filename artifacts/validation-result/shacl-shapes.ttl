@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.

<1fc51efb43855803208d27a6ed9e4e55validation_resultShape> a sh:NodeShape;
    sh:targetClass <https://model.ccmm.cz/vocabulary/ccmm#ValidationResult>;
    sh:class <https://model.ccmm.cz/vocabulary/ccmm#ValidationResult>;
    sh:nodeKind sh:IRI;
    sh:description "Class describing the result of validation testing. It may include validation of metadata, data and/or web services accessing the data."@en;
    sh:name "Validation result"@en.
<6d4f7c63856faa2da3f891c0737fc7f4labelShape> a sh:PropertyShape;
    sh:description "Label of the validation result."@en;
    sh:name "label"@en;
    sh:path rdfs:label;
    sh:datatype <http://www.w3.org/1999/02/22-rdf-syntax-ns#langString>.
<1fc51efb43855803208d27a6ed9e4e55validation_resultShape> sh:property <6d4f7c63856faa2da3f891c0737fc7f4labelShape>.
