		// rdfs:label	"media type"
		// rdfs:comment	"Cette propriété doit être utilisée quand c'est définit le type de média de la distribution en IANA, sinon dcterms:format DOIT être utilisé avec différentes valeurs." ;
	<http://www.w3.org/ns/dcat#byteSize> xsd:integer
		// rdfs:label	"byte size"
		// rdfs:comment	"The size of a Distribution in bytes. " ;
