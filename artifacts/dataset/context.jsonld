{
  "@context": {
    "@version": 1.1,
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "id": "@id",
    "type": "@type",
    "alternate_title": {
      "@id": "https://model.ccmm.cz/vocabulary/ccmm#hasAlternateTitle",
      "@container": "@set",
      "@context": "../alternate-title/context.jsonld"
    },
    "qualified_relation": {
      "@id": "https://model.ccmm.cz/vocabulary/ccmm#qualifiedRelation",
      "@container": "@set",
      "@context": "../resource-to-agent-relationship/context.jsonld"
    },
    "resource_type": {
      "@id": "http://purl.org/dc/terms/type",
      "@context": "../resource-type/context.jsonld"
    },
    "Datová sada": {
      "@id": "http://www.w3.org/ns/dcat#Dataset",
      "@context": {
        "metadata_identification": {
          "@id": "https://model.ccmm.cz/vocabulary/ccmm#isDescribedBy",
          "@container": "@set",
          "@context": "../metadata-record/context.jsonld"
        },
        "identifier": {
          "@id": "https://model.ccmm.cz/vocabulary/ccmm#hasIdentifier",
          "@container": "@set",
          "@context": "../identifier/context.jsonld"
        },
        "version": {
          "@id": "http://www.w3.org/ns/dcat#version",
          "@type": "xsd:string"
        },
        "title": {
          "@id": "http://purl.org/dc/terms/title",
          "@type": "xsd:string"
        },
        "publication_year": {
          "@id": "https://model.ccmm.cz/vocabulary/datacite#relatedItemPublicationYear",
          "@type": "xsd:gYear"
        },
        "time_reference": {
          "@id": "https://model.ccmm.cz/vocabulary/ccmm#hasTimeReference",
          "@container": "@set",
          "@context": "../time-reference/context.jsonld"
        },
        "primary_language": {
          "@id": "http://purl.org/dc/terms/language",
          "@context": "../language-system/context.jsonld"
        },
        "other_language": {
          "@id": "http://purl.org/dc/terms/language",
          "@container": "@set",
          "@context": "../language-system/context.jsonld"
        },
        "terms_of_use": {
          "@id": "https://model.ccmm.cz/vocabulary/datacite#hasRights",
          "@context": "../terms-of-use/context.jsonld"
        },
        "subject": {
          "@id": "https://model.ccmm.cz/vocabulary/datacite#hasSubject",
          "@container": "@set",
          "@context": "../subject/context.jsonld"
        },
        "description": {
          "@id": "https://model.ccmm.cz/vocabulary/datacite#hasDescription",
          "@container": "@set",
          "@context": "../description/context.jsonld"
        },
        "location": {
          "@id": "http://purl.org/dc/terms/spatial",
          "@container": "@set",
          "@context": "../location/context.jsonld"
        },
        "funding_reference": {
          "@id": "https://model.ccmm.cz/vocabulary/datacite#hasFundingReference",
          "@container": "@set",
          "@context": "../funding-reference/context.jsonld"
        },
        "related_resource": {
          "@id": "https://model.ccmm.cz/vocabulary/ccmm#hasRelatedResource",
          "@container": "@set",
          "@context": "../related-resource/context.jsonld"
        },
        "distribution": {
          "@id": "http://www.w3.org/ns/dcat#distribution",
          "@container": "@set",
          "@context": "../distribution-data-service/context.jsonld"
        },
        "validation_result": {
          "@id": "https://model.ccmm.cz/vocabulary/ccmm#hasValidationResult",
          "@container": "@set",
          "@context": "../validation-result/context.jsonld"
        },
        "provenance": {
          "@id": "http://purl.org/dc/terms/provenance",
          "@container": "@set",
          "@context": "../provenance-statement/context.jsonld"
        },
        "additional_publication_year": {
          "@id": "https://model.ccmm.cz/vocabulary/datacite#relatedItemPublicationYear",
