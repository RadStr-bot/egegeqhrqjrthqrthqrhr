    sh:maxCount 1;
    sh:path <http://www.w3.org/2006/time#inXSDDateTime>.

<e82dabfe952021a686e0e23e05068defdate_timeShape> sh:datatype xsd:dateTime.
<2a94d88a63985c1bd5dd8459da37d19bShape> sh:property <e82dabfe952021a686e0e23e05068defdate_timeShape>.
<e199f7d9a28f6ce2fd661a99af5e8000dateShape> a sh:PropertyShape;
