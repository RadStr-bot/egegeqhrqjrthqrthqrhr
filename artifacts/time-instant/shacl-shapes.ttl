@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.

<86361b29e6bd88aa50ea2841449410e5time_instantShape> a sh:NodeShape;
    sh:targetClass <http://www.w3.org/2006/time#Instant>;
    sh:class <http://www.w3.org/2006/time#Instant>;
    sh:nodeKind sh:IRI;
    sh:description "A temporal entity with zero extent or duration."@en, "Una entidad temporal con una extensión o duración cero."@es;
    sh:name "Time instant"@en, "instante de tiempo."@es.
<2a94d88a63985c1bd5dd8459da37d19bShape> a sh:PropertyShape;
    sh:minCount 1;
    sh:maxCount 1;
    sh:path <null>;
    sh:nodeKind sh:IRI;
    a sh:NodeShape;
    sh:targetClass <null>;
    sh:class <null>;
    sh:nodeKind sh:IRI.
<e82dabfe952021a686e0e23e05068defdate_timeShape> a sh:PropertyShape;
