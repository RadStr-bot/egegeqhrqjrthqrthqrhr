{
  "@context": {
    "@version": 1.1,
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "id": "@id",
    "type": "@type",
    "identifier": {
      "@id": "https://model.ccmm.cz/vocabulary/ccmm#hasIdentifier",
      "@container": "@set",
      "@context": "../identifier/context.jsonld"
    },
    "name": {
      "@id": "http://xmlns.com/foaf/0.1/name",
      "@type": "xsd:string"
    },
    "contact_point": {
      "@id": "http://www.w3.org/ns/dcat#contactPoint",
      "@container": "@set",
      "@context": "../contact-details/context.jsonld"
    },
    "Person": {
      "@id": "http://www.w3.org/ns/prov#Person",
      "@context": {
        "given_name": {
          "@id": "http://www.w3.org/2006/vcard/ns#given-name",
          "@type": "xsd:string"
        },
        "family_name": {
          "@id": "http://www.w3.org/2006/vcard/ns#family-name",
          "@type": "xsd:string"
        },
        "affiliation": {
          "@id": "https://model.ccmm.cz/vocabulary/ccmm#hasAffiliation",
          "@container": "@set",
          "@context": "../organization/context.jsonld"
        }
      }
    }
  }
}