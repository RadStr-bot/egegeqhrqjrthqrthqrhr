prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix xsd: <http://www.w3.org/2001/XMLSchema#>

<fcfe954ce1b6f585e9d7282a1c7ebdc3checksum_algorithmShExShape> IRI{
	a [<http://spdx.org/rdf/terms#ChecksumAlgorithm>] ;
	rdfs:label rdf:langString *
		// rdfs:label	"label"
		// rdfs:comment	"A human-readable name for the subject."
}
<50b96d99823f368a54aac52629ba182fchecksumShExShape> IRI{
	a [<http://spdx.org/rdf/terms#Checksum>] ;
	<http://spdx.org/rdf/terms#checksumValue> xsd:hexBinary
		// rdfs:label	"checksum value"
		// rdfs:comment	"A lower case hexadecimal encoded digest value produced using a specific algorithm. " ;
	<http://spdx.org/rdf/terms#algorithm> @<fcfe954ce1b6f585e9d7282a1c7ebdc3checksum_algorithmShExShape>
		// rdfs:label	"uses algorithm"
		// rdfs:comment	"The algorithm used to produce the subject Checksum."
}
