{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/terms-of-use/schema.json",
  "title": "Terms of use",
  "description": "Terms of use defines overall conditions and rights regarding access and usage  of dataset. ",
  "type": "object",
  "required": [
    "id",
    "type",
    "access_rights",
    "license"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "iri"
    },
    "type": {
      "oneOf": [
        {
          "const": "Terms of use"
        },
        {
          "type": "array",
          "contains": {
            "const": "Terms of use"
          },
          "items": {
            "type": "string"
          }
        }
      ]
    },
    "access_rights": {
      "$ref": "../access-rights/schema.json"
    },
    "license": {
      "$ref": "../license-document/schema.json"
    },
    "description": {
      "title": "description",
      "description": "Descriptive text on details of rights and licensing.",
      "type": "array",
      "items": {
        "title": "Text",
        "type": "object",
        "additionalProperties": {
          "title": "Hodnota v jiném jazyce",
          "type": "string"
        },
        "properties": {
          "cs": {
            "title": "Hodnota v českém jazyce",
            "type": "string"
          },
          "en": {
            "title": "Hodnota v anglickém jazyce",
            "type": "string"
          }
        }
      }
    },
    "contact_point": {
      "title": "kontaktní bod",
      "description": "Relevantní kontaktní informace pro katalogizovaný zdroj. Doporučuje se použít slovník VCard.",
      "type": "array",
      "items": {
        "anyOf": [
          {
            "$ref": "../organization/schema.json"
          },
          {
            "$ref": "../person/schema.json"
          }
        ]
      }
    }
  }
}