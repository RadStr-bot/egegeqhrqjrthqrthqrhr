}
<3e02764ab087347fd7f4d986d9d1a0dedistribution_data_serviceShExShape> IRI{
	a [<https://model.ccmm.cz/vocabulary/ccmm#Distribution-DataService>] ;
	<http://purl.org/dc/terms/title> xsd:string
		// rdfs:label	"title"
		// rdfs:comment	"A name given to the distribution." ;
	<http://www.w3.org/ns/dcat#accessService> @<37cab2d8ad3a83961dd7525ae3bcf64bdata_serviceShExShape> *
		// rdfs:label	"has access service"
		// rdfs:comment	"A data service that gives access to the distribution of the dataset." ;
	<http://purl.org/dc/terms/conformsTo> @<0b9dfc920cc2f1b86e3f31a775c68400application_profileShExShape> *
		// rdfs:label	"conforms to specification"
		// rdfs:comment	"An established schema to which the described Distribution conforms." ;
	foaf:page @<a19ec3750f9cac81738cd8448f26565ddocumentationShExShape> *
		// rdfs:label	"has documentation"
		// rdfs:comment	"A page or document about this Distribution." ;
	<http://purl.org/dc/terms/description> rdf:langString *
		// rdfs:label	"description"
		// rdfs:comment	"A free-text account of the Distribution."
}
