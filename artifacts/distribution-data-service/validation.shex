	a [<http://www.w3.org/2006/time#Interval>] ;
	<http://www.w3.org/2006/time#hasBeginning> @<86361b29e6bd88aa50ea2841449410e5time_instantShExShape>
		// rdfs:label	"has beginning"
		// rdfs:comment	"Time instant representing the beginning of a temporal interval." ;
	<http://www.w3.org/2006/time#hasEnd> @<86361b29e6bd88aa50ea2841449410e5time_instantShExShape>
		// rdfs:label	"has end"
		// rdfs:comment	"Time instant representing the end of a temporal interval."
}
<cd487b91c290f904a9765180524b5296date_typeShExShape> IRI{
	a [<http://www.w3.org/2004/02/skos/core#Concept>] ;
	rdfs:label rdf:langString *
		// rdfs:label	"label"
		// rdfs:comment	"Date type label."
}
<b5b1fa4b1c2d1a71d4bf5e25be842343time_referenceShExShape> IRI{
	a [<https://model.ccmm.cz/vocabulary/ccmm#TimeReference>] ;
	<null> @<8aadf9b4787f3b5c0905eac254ba76fatime_intervalShExShape> @<86361b29e6bd88aa50ea2841449410e5time_instantShExShape>
		// rdfs:label	"has temporal representation" ;
	<null> @<8aadf9b4787f3b5c0905eac254ba76fatime_intervalShExShape> @<86361b29e6bd88aa50ea2841449410e5time_instantShExShape>
		// rdfs:label	"has temporal representation" ;
	<https://model.ccmm.cz/vocabulary/ccmm#hasType> @<cd487b91c290f904a9765180524b5296date_typeShExShape>
		// rdfs:label	"has date type"
		// rdfs:comment	"Reference to the codelist of date types." ;
	<https://model.ccmm.cz/vocabulary/datacite#dateInformation> rdf:langString ?
		// rdfs:label	"date information"
		// rdfs:comment	"Additional information to the date in text form."
}
<a6f2f22f499dc324b97d113ea86a5b94resource_typeShExShape> IRI{
	a [<http://www.w3.org/2004/02/skos/core#Concept>] ;
