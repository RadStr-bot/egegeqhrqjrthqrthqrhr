<a2613432d00f1fd8e459f5f78502639crelated_resourceShExShape> IRI{
	a [rdfs:Resource] ;
	<https://model.ccmm.cz/vocabulary/ccmm#hasIdentifier> @<f935935831e21c9c65a09303e825fd65identifierShExShape> *
		// rdfs:label	"has identifier"
		// rdfs:comment	"has identifier" ;
	<http://purl.org/dc/terms/title> xsd:string ?
		// rdfs:label	"title"
		// rdfs:comment	"A name given to the resource." ;
	<https://model.ccmm.cz/vocabulary/ccmm#hasAlternateTitle> @<b59580f13f034e2a989f1b8fe9f13061alternate_titleShExShape> *
		// rdfs:label	"has alternate title" ;
	<https://model.ccmm.cz/vocabulary/ccmm#resourceUrl> xsd:anyURI ?
		// rdfs:label	"resource URL"
		// rdfs:comment	"Human readable resolvable URL representing the resource." ;
	<https://model.ccmm.cz/vocabulary/ccmm#qualifiedRelation> @<21aa4edba7c17161d16bdf23e76fec0eresource_to_agent_relationshipShExShape> *
		// rdfs:label	"qualified relation" ;
	<https://model.ccmm.cz/vocabulary/ccmm#hasTimeReference> @<b5b1fa4b1c2d1a71d4bf5e25be842343time_referenceShExShape> *
		// rdfs:label	"has time reference"
		// rdfs:comment	"Reference to events related to the resource." ;
	<http://purl.org/dc/terms/type> @<a6f2f22f499dc324b97d113ea86a5b94resource_typeShExShape> ?
		// rdfs:label	"has resource type"
		// rdfs:comment	"The resource type of the resource." ;
	<https://model.ccmm.cz/vocabulary/ccmm#hasType> @<8e87a41da7c1af42f0492228f606a133resource_relation_typeShExShape> ?
		// rdfs:label	"has resource relation type"
		// rdfs:comment	"Relation to the relation type between dataset and resource."
}
<37cab2d8ad3a83961dd7525ae3bcf64bdata_serviceShExShape> IRI{
	a [<http://www.w3.org/ns/dcat#DataService>] ;
	rdfs:label rdf:langString *
