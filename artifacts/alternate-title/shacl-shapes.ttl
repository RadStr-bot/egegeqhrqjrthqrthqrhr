@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.

<b59580f13f034e2a989f1b8fe9f13061alternate_titleShape> a sh:NodeShape;
    sh:targetClass <https://model.ccmm.cz/vocabulary/ccmm#AlternateTitle>;
    sh:class <https://model.ccmm.cz/vocabulary/ccmm#AlternateTitle>;
    sh:nodeKind sh:IRI;
    sh:description "Alternate title of the resource."@en;
    sh:name "Alternate title"@en.
<bacd722aafde2b08dda2d86fe82b772dtitleShape> a sh:PropertyShape;
    sh:description "A human-readable name for the subject."@en;
    sh:name "title"@en;
    sh:minCount 1;
    sh:path <http://purl.org/dc/terms/title>;
    sh:datatype <http://www.w3.org/1999/02/22-rdf-syntax-ns#langString>.
<b59580f13f034e2a989f1b8fe9f13061alternate_titleShape> sh:property <bacd722aafde2b08dda2d86fe82b772dtitleShape>.
<d35ed749a5e28b1bf5978eeb796c7b88alternate_title_typeShape> a sh:PropertyShape;
    sh:description "Type of the alternate name relation."@en;
    sh:name "has alternate title type"@en;
    sh:maxCount 1;
    sh:path <https://model.ccmm.cz/vocabulary/ccmm#hasType>;
    sh:nodeKind sh:IRI.
<8d16c5bdc6240234a2a7f88e92f7d6d8alternate_title_typeShape> a sh:NodeShape;
    sh:class <http://www.w3.org/2004/02/skos/core#Concept>;
    sh:nodeKind sh:IRI;
    sh:description "Type of alternate title."@en;
    sh:name "Alternate title type"@en.
<4ce2e08a2e646d41dbda7efeffad2836labelShape> a sh:PropertyShape;
    sh:description "Alternate title type label."@en;
    sh:name "label"@en;
    sh:path rdfs:label;
    sh:datatype <http://www.w3.org/1999/02/22-rdf-syntax-ns#langString>.
<8d16c5bdc6240234a2a7f88e92f7d6d8alternate_title_typeShape> sh:property <4ce2e08a2e646d41dbda7efeffad2836labelShape>.
<d35ed749a5e28b1bf5978eeb796c7b88alternate_title_typeShape> sh:node <8d16c5bdc6240234a2a7f88e92f7d6d8alternate_title_typeShape>.
<b59580f13f034e2a989f1b8fe9f13061alternate_titleShape> sh:property <d35ed749a5e28b1bf5978eeb796c7b88alternate_title_typeShape>.
