prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>

<4cf1c079afd308ac411e316adb29e6bbdescription_typeShExShape> IRI{
	a [<https://model.ccmm.cz/vocabulary/datacite#DescriptionType>] ;
	rdfs:label rdf:langString *
		// rdfs:label	"label"
		// rdfs:comment	"Label of the description type."
}
<15fc8dd2d4739dcca02a2d96786a8febdescriptionShExShape> IRI{
	a [<https://model.ccmm.cz/vocabulary/datacite#Description>] ;
	<https://model.ccmm.cz/vocabulary/datacite#descriptionText> rdf:langString
		// rdfs:label	"description text"
		// rdfs:comment	"Text describing the resource." ;
	<https://model.ccmm.cz/vocabulary/datacite#hasDescriptionType> @<4cf1c079afd308ac411e316adb29e6bbdescription_typeShExShape> ?
		// rdfs:label	"has description type"
		// rdfs:comment	"Relation to the type of the description."
}
