PREFIX ns0: <https://model.ccmm.cz/vocabulary/datacite#>
PREFIX ns1: <http://www.w3.org/2000/01/rdf-schema#>
CONSTRUCT {
  ?v0 a ns0:Description .
  ?v0 ns0:descriptionText ?v1 .
  ?v0 ns0:hasDescriptionType ?v2 .
  ?v2 a ns0:DescriptionType .
  ?v2 ns1:label ?v3 .
}
WHERE {
  ?v0 a ns0:Description .
  ?v0 ns0:descriptionText ?v1 .
  OPTIONAL {
    ?v0 ns0:hasDescriptionType ?v2 .
    OPTIONAL {
      ?v2 a ns0:DescriptionType .
    }
    OPTIONAL {
      ?v2 ns1:label ?v3 .
    }
  }
}
