@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.

<a2fb36fbb73568fe5ebdd6a995db899dorganizationShape> a sh:NodeShape;
    sh:targetClass <http://xmlns.com/foaf/0.1/Agent>;
    sh:class <http://xmlns.com/foaf/0.1/Agent>;
    sh:nodeKind sh:IRI;
    sh:description "Represents a collection of people organized together into a community or other social, commercial or political structure. The group has some common purpose or reason for existence which goes beyond the set of people belonging to it and can act as an Agent. Organizations are often decomposable into hierarchical structures. "@en;
    sh:name "Organization"@en.
<a636fd5d4c23261f8c89bed86221764cidentifierShape> a sh:PropertyShape;
    sh:description "has identifier"@en;
    sh:name "has identifier"@en;
    sh:path <https://model.ccmm.cz/vocabulary/ccmm#hasIdentifier>;
    sh:nodeKind sh:IRI.
<f935935831e21c9c65a09303e825fd65identifierShape> a sh:NodeShape;
    sh:class <http://www.w3.org/ns/adms#Identifier>;
    sh:nodeKind sh:IRI;
    sh:description "Unique and resolvable identifier containing the notation and identifier scheme in the form of URI."@en;
    sh:name "Identifier"@en.
<b0f31fda68cc0108552c0cf8ba5d4ac0valueShape> a sh:PropertyShape;
    sh:description "Value of the identifer within the given identifier scheme."@en;
    sh:name "value"@en;
    sh:minCount 1;
    sh:maxCount 1;
    sh:path <http://www.w3.org/2004/02/skos/core#notation>.

<b0f31fda68cc0108552c0cf8ba5d4ac0valueShape> sh:datatype xsd:string.
