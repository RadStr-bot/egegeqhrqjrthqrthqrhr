    sh:name "in scheme"@en;
    sh:minCount 1;
    sh:maxCount 1;
    sh:path <https://model.ccmm.cz/vocabulary/ccmm#inScheme>;
    sh:nodeKind sh:IRI.
<7afe2fbb01cee0cc873f5666deea53fcidentifier_schemeShape> a sh:NodeShape;
    sh:class <https://model.ccmm.cz/vocabulary/ccmm#IdentifierScheme>;
    sh:nodeKind sh:IRI;
    sh:description "Scheme in which is the identifier value unique, usually representing some authority. Identifier scheme shall always be represented as IRI identifier."@en;
    sh:name "Identifier scheme"@en.
<18fe089cb9037d81660967678a52980alabelShape> a sh:PropertyShape;
    sh:description "Identifier scheme label"@en;
