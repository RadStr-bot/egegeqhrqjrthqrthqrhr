prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix foaf: <http://xmlns.com/foaf/0.1/>
prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix xsd: <http://www.w3.org/2001/XMLSchema#>

<7afe2fbb01cee0cc873f5666deea53fcidentifier_schemeShExShape> IRI{
	a [<https://model.ccmm.cz/vocabulary/ccmm#IdentifierScheme>] ;
	rdfs:label rdf:langString *
		// rdfs:label	"label"
		// rdfs:comment	"Identifier scheme label"
}
<f935935831e21c9c65a09303e825fd65identifierShExShape> IRI{
	a [<http://www.w3.org/ns/adms#Identifier>] ;
	<http://www.w3.org/2004/02/skos/core#notation> xsd:string
		// rdfs:label	"value"
		// rdfs:comment	"Value of the identifer within the given identifier scheme." ;
	<https://model.ccmm.cz/vocabulary/ccmm#inScheme> @<7afe2fbb01cee0cc873f5666deea53fcidentifier_schemeShExShape>
		// rdfs:label	"in scheme"
		// rdfs:comment	"Relation between the identifier and scheme in which it is defined and unique." ;
	<https://model.ccmm.cz/vocabulary/ccmm#authorized> xsd:boolean ?
		// rdfs:label	"authorized"
		// rdfs:comment	"Specifies whether the identifier is authorized by the subject it represents."
}
<c2534f76f2461bbe872ae048e45995c3addressShExShape> IRI{
	a [<http://www.w3.org/ns/locn#Address>] ;
	rdfs:label rdf:langString *
		// rdfs:label	"label"
		// rdfs:comment	"Address label" ;
	<http://www.w3.org/ns/locn#fullAddress> xsd:string *
		// rdfs:label	"full address"
		// rdfs:comment	"The complete address written as a string." ;
	<http://www.w3.org/ns/locn#poBox> xsd:string *
		// rdfs:label	"post office box"
		// rdfs:comment	"A location designator for a postal delivery point at a post office, usually a number." ;
	<http://www.w3.org/ns/locn#thoroughfare> xsd:string *
		// rdfs:label	"thoroughfare"
		// rdfs:comment	"The name of a passage or way through from one location to another." ;
	<http://www.w3.org/ns/locn#locatorDesignator> xsd:string *
		// rdfs:label	"locator designator"
		// rdfs:comment	"A number or sequence of characters that uniquely identifies the locator within the relevant scope." ;
	<http://www.w3.org/ns/locn#locatorName> xsd:string *
		// rdfs:label	"locator name"
		// rdfs:comment	"Proper noun(s) applied to the real world entity identified by the locator. The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building." ;
	<http://www.w3.org/ns/locn#addressArea> xsd:string *
		// rdfs:label	"address area"
		// rdfs:comment	"The name of a geographic area that groups Addresses." ;
	<http://www.w3.org/ns/locn#postName> xsd:string *
		// rdfs:label	"post name"
		// rdfs:comment	"A name created and maintained for postal purposes to identify a subdivision of addresses and postal delivery points. " ;
	<http://www.w3.org/ns/locn#adminUnitL1> xsd:string *
		// rdfs:label	"administrative unit level 1"
		// rdfs:comment	"The name of the uppermost level of the address, almost always a country." ;
	<http://www.w3.org/ns/locn#adminUnitL2> xsd:string *
		// rdfs:label	"administrative unit level 2"
		// rdfs:comment	"The name of a secondary level/region of the address, usually a county, state or other such area that typically encompasses several localities." ;
	<http://www.w3.org/ns/locn#postCode> xsd:string *
		// rdfs:label	"post code"
		// rdfs:comment	"The code created and maintained for postal purposes to identify a subdivision of addresses and postal delivery points."
}
<9456e73e147485c73d4024bfba464d7fcontact_detailsShExShape> IRI{
	a [<https://model.ccmm.cz/vocabulary/ccmm#ContactDetails>] ;
	<https://model.ccmm.cz/vocabulary/ccmm#dataBox> xsd:string *
		// rdfs:label	"data box"
		// rdfs:comment	"Code of the data box." ;
	<https://model.ccmm.cz/vocabulary/ccmm#email> xsd:string *
		// rdfs:label	"email"
		// rdfs:comment	"Email address." ;
	<https://model.ccmm.cz/vocabulary/ccmm#phone> xsd:string *
		// rdfs:label	"phone"
		// rdfs:comment	"Phone number" ;
	<http://www.w3.org/2006/vcard/ns#hasAddress> @<c2534f76f2461bbe872ae048e45995c3addressShExShape> *
		// rdfs:label	"has address"
		// rdfs:comment	"To specify the components of the delivery address for the object"
}
<a2fb36fbb73568fe5ebdd6a995db899dorganizationShExShape> IRI{
	a [foaf:Agent] ;
	<https://model.ccmm.cz/vocabulary/ccmm#hasIdentifier> @<f935935831e21c9c65a09303e825fd65identifierShExShape> *
		// rdfs:label	"has identifier"
		// rdfs:comment	"has identifier" ;
	foaf:name xsd:string
		// rdfs:label	"name"
		// rdfs:comment	"Name of the agent." ;
	<http://www.w3.org/2006/vcard/ns#organization-name> rdf:langString *
		// rdfs:label	"alternate name"
		// rdfs:comment	"To specify the organizational name associated with the object" ;
	<http://www.w3.org/ns/dcat#contactPoint> @<9456e73e147485c73d4024bfba464d7fcontact_detailsShExShape> *
		// rdfs:label	"Punto de contacto"
		// rdfs:comment	"Información relevante de contacto para el recurso catalogado. Se recomienda el uso de vCard."
}
<9b5e22c42c2fde6469556458ce8ebdafpersonShExShape> IRI{
	a [<http://www.w3.org/ns/prov#Person>] ;
	<https://model.ccmm.cz/vocabulary/ccmm#hasIdentifier> @<f935935831e21c9c65a09303e825fd65identifierShExShape> *
		// rdfs:label	"has identifier"
		// rdfs:comment	"has identifier" ;
	foaf:name xsd:string
		// rdfs:label	"name"
		// rdfs:comment	"Name of the agent." ;
	<http://www.w3.org/2006/vcard/ns#given-name> xsd:string *
		// rdfs:label	"given name"
		// rdfs:comment	"The given name associated with the person." ;
	<http://www.w3.org/2006/vcard/ns#family-name> xsd:string *
		// rdfs:label	"family name"
		// rdfs:comment	"The family name associated with the person." ;
	<http://www.w3.org/ns/dcat#contactPoint> @<9456e73e147485c73d4024bfba464d7fcontact_detailsShExShape> *
		// rdfs:label	"Punto de contacto"
		// rdfs:comment	"Información relevante de contacto para el recurso catalogado. Se recomienda el uso de vCard." ;
	<https://model.ccmm.cz/vocabulary/ccmm#hasAffiliation> @<a2fb36fbb73568fe5ebdd6a995db899dorganizationShExShape> *
		// rdfs:label	"has affiliation"
		// rdfs:comment	"Affiliation of the person to an organization."
}
