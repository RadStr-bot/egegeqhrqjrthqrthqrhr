{
  "@context": {
    "@version": 1.1,
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "id": "@id",
    "type": "@type",
    "Identifier": {
      "@id": "http://www.w3.org/ns/adms#Identifier",
      "@context": {
        "value": {
          "@id": "http://www.w3.org/2004/02/skos/core#notation",
          "@type": "xsd:string"
        },
        "scheme": {
          "@id": "https://model.ccmm.cz/vocabulary/ccmm#inScheme",
          "@context": "../identifier-scheme/context.jsonld"
        },
        "authorized": {
          "@id": "https://model.ccmm.cz/vocabulary/ccmm#authorized",
          "@type": "xsd:boolean"
        }
      }
    }
  }
}