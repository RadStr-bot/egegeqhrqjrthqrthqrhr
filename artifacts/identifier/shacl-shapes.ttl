@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.

<f935935831e21c9c65a09303e825fd65identifierShape> a sh:NodeShape;
    sh:targetClass <http://www.w3.org/ns/adms#Identifier>;
    sh:class <http://www.w3.org/ns/adms#Identifier>;
    sh:nodeKind sh:IRI;
    sh:description "Unique and resolvable identifier containing the notation and identifier scheme in the form of URI."@en;
    sh:name "Identifier"@en.
<b0f31fda68cc0108552c0cf8ba5d4ac0valueShape> a sh:PropertyShape;
    sh:description "Value of the identifer within the given identifier scheme."@en;
    sh:name "value"@en;
    sh:minCount 1;
    sh:maxCount 1;
    sh:path <http://www.w3.org/2004/02/skos/core#notation>.

<b0f31fda68cc0108552c0cf8ba5d4ac0valueShape> sh:datatype xsd:string.
<f935935831e21c9c65a09303e825fd65identifierShape> sh:property <b0f31fda68cc0108552c0cf8ba5d4ac0valueShape>.
<f19bcecd5dc95e53541b5e42ad92bf5cschemeShape> a sh:PropertyShape;
    sh:description "Relation between the identifier and scheme in which it is defined and unique."@en;
    sh:name "in scheme"@en;
    sh:minCount 1;
    sh:maxCount 1;
    sh:path <https://model.ccmm.cz/vocabulary/ccmm#inScheme>;
    sh:nodeKind sh:IRI.
<7afe2fbb01cee0cc873f5666deea53fcidentifier_schemeShape> a sh:NodeShape;
    sh:class <https://model.ccmm.cz/vocabulary/ccmm#IdentifierScheme>;
    sh:nodeKind sh:IRI;
    sh:description "Scheme in which is the identifier value unique, usually representing some authority. Identifier scheme shall always be represented as IRI identifier."@en;
    sh:name "Identifier scheme"@en.
<18fe089cb9037d81660967678a52980alabelShape> a sh:PropertyShape;
    sh:description "Identifier scheme label"@en;
    sh:name "label"@en;
    sh:path rdfs:label;
    sh:datatype <http://www.w3.org/1999/02/22-rdf-syntax-ns#langString>.
<7afe2fbb01cee0cc873f5666deea53fcidentifier_schemeShape> sh:property <18fe089cb9037d81660967678a52980alabelShape>.
<f19bcecd5dc95e53541b5e42ad92bf5cschemeShape> sh:node <7afe2fbb01cee0cc873f5666deea53fcidentifier_schemeShape>.
<f935935831e21c9c65a09303e825fd65identifierShape> sh:property <f19bcecd5dc95e53541b5e42ad92bf5cschemeShape>.
<1dea87a9b8d56e30e22ffaf15cf95d5eauthorizedShape> a sh:PropertyShape;
    sh:description "Specifies whether the identifier is authorized by the subject it represents."@en;
    sh:name "authorized"@en;
    sh:maxCount 1;
    sh:path <https://model.ccmm.cz/vocabulary/ccmm#authorized>;
    sh:datatype xsd:boolean.
<f935935831e21c9c65a09303e825fd65identifierShape> sh:property <1dea87a9b8d56e30e22ffaf15cf95d5eauthorizedShape>.
