	a [<http://www.w3.org/ns/locn#Geometry>] ;
	rdfs:label rdf:langString *
		// rdfs:label	"label"
		// rdfs:comment	"Label of geometry object." ;
	<http://www.opengis.net/ont/geosparql#asGML> <http://www.opengis.net/ont/geosparql#gmlLiteral> ?
