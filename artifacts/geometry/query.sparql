PREFIX ns0: <http://www.w3.org/ns/locn#>
PREFIX ns1: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX ns2: <http://www.opengis.net/ont/geosparql#>
CONSTRUCT {
  ?v0 a ns0:Geometry .
  ?v0 ns1:label ?v1 .
  ?v0 ns2:asGML ?v2 .
  ?v0 ns2:asWKT ?v3 .
}
WHERE {
  ?v0 a ns0:Geometry .
  OPTIONAL {
    ?v0 ns1:label ?v1 .
  }
  OPTIONAL {
    ?v0 ns2:asGML ?v2 .
  }
  OPTIONAL {
    ?v0 ns2:asWKT ?v3 .
  }
}
