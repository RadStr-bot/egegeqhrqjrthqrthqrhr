@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.

<9456e73e147485c73d4024bfba464d7fcontact_detailsShape> a sh:NodeShape;
    sh:targetClass <https://model.ccmm.cz/vocabulary/ccmm#ContactDetails>;
    sh:class <https://model.ccmm.cz/vocabulary/ccmm#ContactDetails>;
    sh:nodeKind sh:IRI;
    sh:description "Details to contact the agent in a relationship to the resource."@en;
    sh:name "Contact details"@en.
<49f1a2fefd164b655b2182fc4df9b91cdata_boxShape> a sh:PropertyShape;
    sh:description "Code of the data box."@en;
    sh:name "data box"@en;
    sh:path <https://model.ccmm.cz/vocabulary/ccmm#dataBox>.

<49f1a2fefd164b655b2182fc4df9b91cdata_boxShape> sh:datatype xsd:string.
<9456e73e147485c73d4024bfba464d7fcontact_detailsShape> sh:property <49f1a2fefd164b655b2182fc4df9b91cdata_boxShape>.
<341783f3d6bf310bff1e63846e09c41femailShape> a sh:PropertyShape;
    sh:description "Email address."@en;
    sh:name "email"@en;
    sh:path <https://model.ccmm.cz/vocabulary/ccmm#email>;
    sh:datatype xsd:string.
<9456e73e147485c73d4024bfba464d7fcontact_detailsShape> sh:property <341783f3d6bf310bff1e63846e09c41femailShape>.
<9eb0de492b731be3b1dc37a4947aaf40phoneShape> a sh:PropertyShape;
    sh:description "Phone number"@en;
    sh:name "phone"@en;
    sh:path <https://model.ccmm.cz/vocabulary/ccmm#phone>;
    sh:datatype xsd:string.
<9456e73e147485c73d4024bfba464d7fcontact_detailsShape> sh:property <9eb0de492b731be3b1dc37a4947aaf40phoneShape>.
<8bf95cab24758a3cab0e548952aa55bbaddressShape> a sh:PropertyShape;
    sh:description "To specify the components of the delivery address for the object"@en;
    sh:name "has address"@en;
    sh:path <http://www.w3.org/2006/vcard/ns#hasAddress>;
    sh:nodeKind sh:IRI.
<c2534f76f2461bbe872ae048e45995c3addressShape> a sh:NodeShape;
    sh:class <http://www.w3.org/ns/locn#Address>;
    sh:nodeKind sh:IRI;
    sh:description "A spatial object that in a human-readable way identifies a fixed location. "@en;
    sh:name "Address"@en.
<778acca3f6448fa9df3f225e85c0fd10labelShape> a sh:PropertyShape;
    sh:description "Address label"@en;
    sh:name "label"@en;
    sh:path rdfs:label;
    sh:datatype <http://www.w3.org/1999/02/22-rdf-syntax-ns#langString>.
<c2534f76f2461bbe872ae048e45995c3addressShape> sh:property <778acca3f6448fa9df3f225e85c0fd10labelShape>.
<0f0a4f4654b170e7326e9b542e91c06ffull_addressShape> a sh:PropertyShape;
    sh:description "The complete address written as a string."@en;
    sh:name "full address"@en;
    sh:path <http://www.w3.org/ns/locn#fullAddress>;
    sh:datatype xsd:string.
<c2534f76f2461bbe872ae048e45995c3addressShape> sh:property <0f0a4f4654b170e7326e9b542e91c06ffull_addressShape>.
<3e73694e1cac2dec5af08714519e6068po_boxShape> a sh:PropertyShape;
    sh:description "A location designator for a postal delivery point at a post office, usually a number."@en;
    sh:name "post office box"@en;
    sh:path <http://www.w3.org/ns/locn#poBox>;
    sh:datatype xsd:string.
<c2534f76f2461bbe872ae048e45995c3addressShape> sh:property <3e73694e1cac2dec5af08714519e6068po_boxShape>.
<f271371d0b8fcb3fa9f81f6c9f1ca98bthoroughfareShape> a sh:PropertyShape;
    sh:description "The name of a passage or way through from one location to another."@en;
    sh:name "thoroughfare"@en;
    sh:path <http://www.w3.org/ns/locn#thoroughfare>;
    sh:datatype xsd:string.
<c2534f76f2461bbe872ae048e45995c3addressShape> sh:property <f271371d0b8fcb3fa9f81f6c9f1ca98bthoroughfareShape>.
<1199e75fb9aa5861bdf56b2238321877locator_designatorShape> a sh:PropertyShape;
    sh:description "A number or sequence of characters that uniquely identifies the locator within the relevant scope."@en;
    sh:name "locator designator"@en;
    sh:path <http://www.w3.org/ns/locn#locatorDesignator>;
    sh:datatype xsd:string.
<c2534f76f2461bbe872ae048e45995c3addressShape> sh:property <1199e75fb9aa5861bdf56b2238321877locator_designatorShape>.
<49a266bd63398074c997c1626be86ca1locator_nameShape> a sh:PropertyShape;
    sh:description "Proper noun(s) applied to the real world entity identified by the locator. The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building."@en;
    sh:name "locator name"@en;
    sh:path <http://www.w3.org/ns/locn#locatorName>;
    sh:datatype xsd:string.
<c2534f76f2461bbe872ae048e45995c3addressShape> sh:property <49a266bd63398074c997c1626be86ca1locator_nameShape>.
<6a2c7d30e3cb9cf2687c370bd5975cdeaddress_areaShape> a sh:PropertyShape;
    sh:description "The name of a geographic area that groups Addresses."@en;
    sh:name "address area"@en;
    sh:path <http://www.w3.org/ns/locn#addressArea>;
    sh:datatype xsd:string.
<c2534f76f2461bbe872ae048e45995c3addressShape> sh:property <6a2c7d30e3cb9cf2687c370bd5975cdeaddress_areaShape>.
<9faa98d324b9a406fba09dbc2d210271post_nameShape> a sh:PropertyShape;
    sh:description "A name created and maintained for postal purposes to identify a subdivision of addresses and postal delivery points. "@en;
    sh:name "post name"@en;
    sh:path <http://www.w3.org/ns/locn#postName>;
    sh:datatype xsd:string.
<c2534f76f2461bbe872ae048e45995c3addressShape> sh:property <9faa98d324b9a406fba09dbc2d210271post_nameShape>.
<7ef447f72b10eff30aa3a957770d61e8administrative_unit_level_1Shape> a sh:PropertyShape;
    sh:description "The name of the uppermost level of the address, almost always a country."@en;
    sh:name "administrative unit level 1"@en;
    sh:path <http://www.w3.org/ns/locn#adminUnitL1>;
    sh:datatype xsd:string.
<c2534f76f2461bbe872ae048e45995c3addressShape> sh:property <7ef447f72b10eff30aa3a957770d61e8administrative_unit_level_1Shape>.
<3f23b86b59453dadbff241a334a13929administrative_unit_level_2Shape> a sh:PropertyShape;
    sh:description "The name of a secondary level/region of the address, usually a county, state or other such area that typically encompasses several localities."@en;
    sh:name "administrative unit level 2"@en;
    sh:path <http://www.w3.org/ns/locn#adminUnitL2>;
    sh:datatype xsd:string.
<c2534f76f2461bbe872ae048e45995c3addressShape> sh:property <3f23b86b59453dadbff241a334a13929administrative_unit_level_2Shape>.
<2b7e0a77585eb2eb360e8b29d9aabd11post_codeShape> a sh:PropertyShape;
    sh:description "The code created and maintained for postal purposes to identify a subdivision of addresses and postal delivery points."@en;
    sh:name "post code"@en;
    sh:path <http://www.w3.org/ns/locn#postCode>;
    sh:datatype xsd:string.
<c2534f76f2461bbe872ae048e45995c3addressShape> sh:property <2b7e0a77585eb2eb360e8b29d9aabd11post_codeShape>.
<8bf95cab24758a3cab0e548952aa55bbaddressShape> sh:node <c2534f76f2461bbe872ae048e45995c3addressShape>.
<9456e73e147485c73d4024bfba464d7fcontact_detailsShape> sh:property <8bf95cab24758a3cab0e548952aa55bbaddressShape>.
