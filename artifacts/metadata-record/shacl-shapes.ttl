    sh:path <http://purl.org/dc/terms/relation>;
    sh:nodeKind sh:IRI.
<a2fb36fbb73568fe5ebdd6a995db899dorganizationShape> a sh:NodeShape;
    sh:class <http://xmlns.com/foaf/0.1/Agent>;
    sh:nodeKind sh:IRI;
    sh:description "Represents a collection of people organized together into a community or other social, commercial or political structure. The group has some common purpose or reason for existence which goes beyond the set of people belonging to it and can act as an Agent. Organizations are often decomposable into hierarchical structures. "@en;
    sh:name "Organization"@en.
