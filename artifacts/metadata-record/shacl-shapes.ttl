<4864a32fac491f5216ce50437bdc8678qualified_relationShape> a sh:PropertyShape;
    sh:description "Enlace a una descripción de la relación con otro recurso."@es, "Link a una descrizione di una relazione con un'altra risorsa."@it, "Link to a description of a relationship between metadata record and agent with the specification of the role of agent in this relationship."@en, "Odkaz na popis vztahu s jiným zdrojem."@cs, "Reference til en beskrivelse af en relation til en anden ressource."@da;
    sh:minCount 1;
    sh:path <null>;
    sh:nodeKind sh:IRI.
<21aa4edba7c17161d16bdf23e76fec0eresource_to_agent_relationshipShape> a sh:NodeShape;
    sh:targetClass <https://model.ccmm.cz/vocabulary/ccmm#ResourceToAgentRelationship>;
    sh:class <https://model.ccmm.cz/vocabulary/ccmm#ResourceToAgentRelationship>;
    sh:nodeKind sh:IRI;
    sh:description "An association class for attaching additional information to a relationship between Resource and Agent."@en;
    sh:name "Resource to agent relationship"@en.
<3bab02aadc8a14baa6eb4382feeef477relationShape> a sh:PropertyShape;
    sh:description "Specifies the agent an a given role in the relationship with the resource."@en;
    sh:name "has related agent"@en;
