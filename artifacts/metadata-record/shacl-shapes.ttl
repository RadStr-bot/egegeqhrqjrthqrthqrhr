    sh:description "Language label"@en;
    sh:name "label"@en;
    sh:path rdfs:label;
    sh:datatype <http://www.w3.org/1999/02/22-rdf-syntax-ns#langString>.
<0fde6ec94d8ebfd388d835f27d4b6484language_systemShape> sh:property <c3cfdbe7269745b1167aa96f54752c37labelShape>.
